esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules/@playwright/mcp/node_modules:/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules/@playwright/node_modules:/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules:/workspace/app/frontend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules/@playwright/mcp/node_modules:/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules/@playwright/node_modules:/workspace/app/frontend/node_modules/.pnpm/@playwright+mcp@0.0.36_hono@4.11.7/node_modules:/workspace/app/frontend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@playwright/mcp/cli.js" "$@"
else
  exec node  "$basedir/../@playwright/mcp/cli.js" "$@"
fi
